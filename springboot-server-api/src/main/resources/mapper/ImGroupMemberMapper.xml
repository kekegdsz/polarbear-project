<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.undersky.api.springbootserverapi.im.mapper.ImGroupMemberMapper">

    <insert id="insert">
        INSERT INTO im_group_members (group_id, user_id) VALUES (#{groupId}, #{userId})
    </insert>

    <delete id="deleteMember">
        DELETE FROM im_group_members WHERE group_id = #{groupId} AND user_id = #{userId}
    </delete>

    <select id="countMember" resultType="int">
        SELECT COUNT(1) FROM im_group_members WHERE group_id = #{groupId} AND user_id = #{userId}
    </select>
</mapper>
