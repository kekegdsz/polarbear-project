<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AndroidIm" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/wx_green</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="android:colorBackground">@color/wx_bg</item>
        <item name="colorSurface">@color/wx_surface</item>
        <item name="colorSurfaceVariant">@color/wx_composer_fill</item>
        <item name="colorOnSurfaceVariant">@color/wx_sub</item>
        <item name="colorOutline">@color/wx_line</item>
        <item name="colorOutlineVariant">#E8EBF0</item>
        <item name="android:statusBarColor">@color/wx_nav</item>
        <item name="android:navigationBarColor">@color/wx_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <!-- targetSdk 35 默认边到边时，与手动 insets 配合；低版本忽略 -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement" tools:targetApi="35">true</item>
    </style>

    <style name="Theme.AndroidIm.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/wx_nav</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_simple</item>
        <item name="postSplashScreenTheme">@style/Theme.AndroidIm</item>
    </style>
</resources>
